# Valores posibles: dev, test, prod
ENV=dev
SECRET_KEY=cambiar-por-uno-generado-con-get_random_secret_key
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

DATABASE_USER=postgres
DATABASE_CLAVE=
DATABASE_HOST=localhost
DATABASE_NAME=bdtorio
DATABASE_PORT=5432

# Logging
LOG_LEVEL=INFO
DJANGO_LOG_LEVEL=INFO

# URLs
BACKEND_URL=http://localhost:8000
FRONTEND_URL=http://localhost:4200
ZINC_URL=http://localhost:3000

# Cloudflare Turnstile
TURNSTILE_ENABLED=False
TURNSTILE_SECRET_KEY=

# API Docs (solo activar en dev/staging)
ENABLE_API_DOCS=False

# Solo en producción (settings.prod)
# CORS_ALLOWED_ORIGINS=https://reddoc.co,https://www.reddoc.co
# SECURE_SSL_REDIRECT=True
