# Valores posibles: dev, test, prod
ENV=dev
SECRET_KEY=cambiar-por-uno-generado-con-get_random_secret_key
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

DATABASE_USER=postgres
DATABASE_CLAVE=
DATABASE_HOST=localhost
DATABASE_NAME=bdtorio
DATABASE_PORT=5432

# Logging
LOG_LEVEL=INFO
DJANGO_LOG_LEVEL=INFO

# URLs
BACKEND_URL=http://localhost:8000
FRONTEND_URL=http://localhost:4200
ZINC_URL=http://localhost:3000
TENANT_BASE_DOMAIN=localhost

# Cloudflare Turnstile
TURNSTILE_ENABLED=False
TURNSTILE_SECRET_KEY=

# API Docs (solo activar en dev/staging)
ENABLE_API_DOCS=False

# Backblaze B2
B2_KEY_ID=
B2_APP_KEY=
# Ejemplo: https://s3.us-west-004.backblazeb2.com
B2_ENDPOINT_URL=
B2_BUCKET_PUBLICO=
B2_BUCKET_PRIVADO=
# Ejemplo: https://{bucket-publico}.s3.us-west-004.backblazeb2.com
B2_CDN_URL_PUBLICO=

# Solo en producción (settings.prod)
